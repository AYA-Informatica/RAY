{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["dub1"],
  "functions": {
    "src/app/**": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/expire-listings",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/purge-messages",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/sweep-storage",
      "schedule": "0 5 * * *"
    }
  ]
}
