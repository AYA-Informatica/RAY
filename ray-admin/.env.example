# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps (for location features)
VITE_GOOGLE_MAPS_API_KEY=your_maps_key_here

# App Config
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development
VITE_FUNCTIONS_BASE_URL=https://us-central1-your-project.cloudfunctions.net
# Backward-compatible alias; prefer VITE_FUNCTIONS_BASE_URL.
VITE_API_BASE_URL=https://us-central1-your-project.cloudfunctions.net
VITE_DEBUG_API=true
