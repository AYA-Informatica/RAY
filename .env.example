# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase Postgres via PgBouncer)
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.your-project:your-password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=RAY
ALLOWED_ORIGINS=http://localhost:3000

# Cron job secret (generate with: openssl rand -hex 48)
CRON_SECRET=your-cron-secret
