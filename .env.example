# ============================================================================
# RAY — Environment Variables Template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase  (Project Settings -> API)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-public-key>"
# Server-only. Bypasses RLS — used by the auth->public.User sync + admin tasks.
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# ----------------------------------------------------------------------------
# Database  (Project Settings -> Database -> Connection string)
# Use the pooled connection (port 6543) for the app; direct (5432) for migrations.
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Comma-separated allowed origins for CORS in production, e.g. https://ray.rw,https://www.ray.rw
ALLOWED_ORIGINS="http://localhost:3000"

# ----------------------------------------------------------------------------
# Rate limiting  (Upstash Redis — https://console.upstash.com)
# Optional in dev: if absent, the limiter degrades to a no-op (logs a warning).
# ----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ----------------------------------------------------------------------------
# Google OAuth is configured INSIDE Supabase (Auth -> Providers -> Google),
# not here. You only need the Supabase keys above. See README "Auth setup".
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Cron (Vercel Cron Jobs). A shared secret so only Vercel can trigger the
# listing-expiry endpoint. Generate any long random string.
# Tip: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ----------------------------------------------------------------------------
CRON_SECRET="<generate-a-long-random-string>"
