{
  "expo": {
    "name": "RAY",
    "slug": "ray-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ray",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8390E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "rw.ray.app",
      "infoPlist": {
        "NSCameraUsageDescription": "RAY needs camera access to take photos of items you want to sell.",
        "NSPhotoLibraryUsageDescription": "RAY needs photo library access to upload listing images.",
        "NSLocationWhenInUseUsageDescription": "RAY uses your location to show listings near you.",
        "NSLocationAlwaysUsageDescription": "RAY uses your location to show listings near you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8390E"
      },
      "package": "rw.ray.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8390E",
          "sounds": ["./assets/notification.wav"]
        }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Allow RAY to use your location." }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": { "eas": { "projectId": "your-eas-project-id" } }
  }
}
