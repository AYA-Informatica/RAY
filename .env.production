# ----------------------------------------------------------------------------
# Google OAuth Configuration
# Configure INSIDE Supabase (not here):
# 1. Go to Supabase Dashboard → Authentication → Providers → Google
# 2. Enable Google provider
# 3. Add your Google Cloud OAuth credentials
# 4. Set authorized redirect URI: https://your-domain.com/auth/callback
# 
# You also need to configure Google Cloud Console:
# - Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# - Add authorized redirect URIs:
#   * Development: http://localhost:3000/auth/callback
#   * Production: https://ray.rw/auth/callback
# Status: ✅ DONE - Configured in Supabase
# ----------------------------------------------------------------------------

# Optional: If you want to track these locally (not used by code, for reference)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-your-client-secret"

# ----------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------

# Your production domain (update before deploying)
NEXT_PUBLIC_SITE_URL="https://ray-production.vercel.app"
NEXT_PUBLIC_SITE_NAME="Ray"

# Allowed origins for CORS (comma-separated, no spaces)
# Include both www and non-www versions if using both
ALLOWED_ORIGINS="https://ray-production.vercel.app,https://ray-production-git-main.vercel.app"

# Node environment (automatically set by Vercel, but useful for local testing)
NODE_ENV="production"

# ----------------------------------------------------------------------------
# Security & Cron Jobs
# ----------------------------------------------------------------------------

# Secret for protecting cron endpoints
# Generated secure random string (96 hex characters)
CRON_SECRET="262bf2b7a25e54ccd77413d305077efc605471e5e400bcc5f4060cf7042bece608386087ac727c3127b88235aeb5eeed"

# ----------------------------------------------------------------------------
# Optional: Logging & Monitoring
