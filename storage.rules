rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Listing images ─────────────────────────────────
    // Anyone authenticated can upload to their own listing folder
    // Anyone can read (public listings)
    match /listings/{userId}/{listingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024   // 10 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // ── User avatars ───────────────────────────────────
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024    // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // ── Chat images ────────────────────────────────────
    match /chat/{conversationId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Block everything else ──────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
