# ============================================
# RAY Web App - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Firebase Configuration
# ============================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ============================================
# Image Upload Configuration
# ============================================
# Choose: 'cloudinary' (recommended) or 'firebase'
VITE_IMAGE_PROVIDER=cloudinary

# Cloudinary Configuration (if using cloudinary)
# Sign up at: https://cloudinary.com/users/register_free
# Setup guide: See CLOUDINARY_SETUP_GUIDE.md
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=ray_listings

# ============================================
# App Configuration
# ============================================
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development
VITE_FUNCTIONS_BASE_URL=
VITE_API_BASE_URL=
VITE_DEBUG_API=true

# ============================================
# Optional: Google Maps
# ============================================
VITE_GOOGLE_MAPS_API_KEY=

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 
# 1. Firebase Setup:
#    - See FIREBASE_SETUP_GUIDE.md
#    - Fill in all VITE_FIREBASE_* values above
#
# 2. Image Upload Setup (Choose ONE):
#    
#    Option A: Cloudinary (Recommended)
#    - See CLOUDINARY_SETUP_GUIDE.md
#    - Set VITE_IMAGE_PROVIDER=cloudinary
#    - Fill in VITE_CLOUDINARY_CLOUD_NAME
#    - Benefits: Auto-optimization, 25GB free, faster
#    
#    Option B: Firebase Storage
#    - Set VITE_IMAGE_PROVIDER=firebase
#    - Enable Storage in Firebase Console
#    - Requires Blaze plan (credit card)
#
# 3. Start dev server:
#    npm run dev
#
# ============================================
