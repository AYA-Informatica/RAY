# ─── Firebase ─────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your_vapid_key_for_web_push

# ─── Image Provider ───────────────────────────
# Set to "cloudinary" or "firebase"
VITE_IMAGE_PROVIDER=firebase
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# ─── API ──────────────────────────────────────
VITE_FUNCTIONS_BASE_URL=https://us-central1-your_project.cloudfunctions.net
VITE_API_BASE_URL=https://us-central1-your_project.cloudfunctions.net

# ─── Maps ─────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key

# ─── App ──────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development
VITE_DEBUG_API=false
