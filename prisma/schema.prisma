// ============================================================================
// RAY — Prisma Schema (MVP Foundation)
// ----------------------------------------------------------------------------
// Identity model: Supabase Auth UUID is the global anchor. A PostgreSQL trigger
// (see prisma/migrations or the SQL in README) copies auth.users -> public.User
// on signup. User.id === auth.uid().
//
// Design references:
//   - SYSTEM ARCHITECTURE (MVP FOUNDATION)
//   - PRODUCTION-GRADE ENGINEERING FOUNDATION  (enums, indexes, cascades)
//   - PRODUCT EXPERIENCE PRINCIPLE              (CategoryAttribute system)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  USED
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  REMOVED
  FLAGGED
}

enum ReportReason {
  SPAM
  FAKE
  STOLEN
  HARASSMENT
  SCAM
  INAPPROPRIATE
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum AttributeType {
  TEXT
  NUMBER
  SELECT
  BOOLEAN
}

// ---------------------------------------------------------------------------
// User  — public marketplace identity, mirrored from Supabase auth.users
// ---------------------------------------------------------------------------

model User {
  id           String   @id @db.Uuid // == auth.uid()
  email        String   @unique
  name         String?
  avatarUrl    String?
  bio          String?

  city         String?
  district     String?
  neighborhood String?
  province     String?

  pushToken    String? // Expo push token, registered by the mobile app after sign-in

  role         UserRole  @default(USER)
  isBanned     Boolean   @default(false)
  deletedAt    DateTime? // set on account deletion (anonymize-in-place) -- NULL means active

  lastSeenAt   DateTime  @default(now())

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  listings              Listing[]
  favorites             Favorite[]
  sentMessages          Message[]      @relation("SentMessages")
  buyerConversations    Conversation[] @relation("BuyerConversations")
  sellerConversations   Conversation[] @relation("SellerConversations")
  reports               Report[]
  blocksMade            Block[]        @relation("Blocker")
  blocksReceived        Block[]        @relation("Blocked")
  adminActions          AdminAction[]  @relation("AdminActions")

  @@index([city])
  @@index([district])
  @@index([province])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Block — a user can block another user (chat safety control)
// ---------------------------------------------------------------------------

model Block {
  id        String   @id @default(cuid())

  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ---------------------------------------------------------------------------
// Category + dynamic attribute system
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String
  nameRw    String? // Kinyarwanda display name
  nameFr    String? // French display name
  slug      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listings   Listing[]
  attributes CategoryAttribute[]
}

/// Schema-driven listing fields. Lets each category declare its own structured
/// inputs (Brand, Storage, Year, Bedrooms…) WITHOUT new DB columns or migrations.
model CategoryAttribute {
  id          String        @id @default(cuid())

  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  label       String
  key         String
  type        AttributeType
  required    Boolean       @default(false)
  placeholder String?
  options     Json? // for SELECT types: ["Apple", "Samsung", ...]
  order       Int           @default(0)

  createdAt   DateTime      @default(now())

  values      ListingAttributeValue[]

  @@unique([categoryId, key])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Listing — the heart of RAY
// ---------------------------------------------------------------------------

model Listing {
  id           String        @id @default(cuid())

  title        String
  description  String        @db.Text
  price        Int
  negotiable   Boolean       @default(true)
  condition    Condition

  city         String
  district     String
  neighborhood String?
  province     String?
  sector       String? // replaces neighborhood for Rwanda-accurate labelling
  village      String? // free-text cell/village
  latitude     Float?
  longitude    Float?

  status       ListingStatus @default(ACTIVE)
  featured     Boolean       @default(false)
  views        Int           @default(0)

  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  userId       String        @db.Uuid
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])

  images          ListingImage[]
  favorites       Favorite[]
  reports         Report[]
  conversations   Conversation[]
  attributeValues ListingAttributeValue[]
  viewRecords     ListingView[]

  @@index([city])
  @@index([district])
  @@index([province])
  @@index([sector])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([createdAt])
  @@index([status, createdAt])
}

/// Deduplication table for listing view counts.
/// One row per (listing, visitor, calendar-day) — guarantees a single
/// increment no matter how many times the same person reloads the page.
model ListingView {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  /// Authenticated users: their UUID. Anonymous: SHA-256(ip:ua) truncated to 32 hex chars.
  visitorKey String
  /// YYYY-MM-DD — resets the dedup window at midnight UTC.
  viewedDate String

  @@unique([listingId, visitorKey, viewedDate])
  @@index([listingId])
}

model ListingImage {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([listingId])
}

model ListingAttributeValue {
  id          String            @id @default(cuid())

  listingId   String
  listing     Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  attributeId String
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  value       String

  @@unique([listingId, attributeId])
  @@index([listingId])
  @@index([attributeId])
}

// ---------------------------------------------------------------------------
// Favorites
// ---------------------------------------------------------------------------

model Favorite {
  id        String   @id @default(cuid())

  userId    String   @db.Uuid
  listingId String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Chat
// ---------------------------------------------------------------------------

model Conversation {
  id        String   @id @default(cuid())

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  buyerId   String   @db.Uuid
  sellerId  String   @db.Uuid
  buyer     User     @relation("BuyerConversations", fields: [buyerId], references: [id])
  seller    User     @relation("SellerConversations", fields: [sellerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerHiddenAt  DateTime?
  sellerHiddenAt DateTime?

  messages  Message[]

  @@unique([listingId, buyerId]) // one thread per buyer per listing
  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([buyerId, updatedAt])
  @@index([sellerId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String       @db.Uuid
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  content        String?      @db.Text
  imageUrl       String?
  latitude       Float?
  longitude      Float?
  offerAmount    Float?       // buyer-proposed price (null = regular message)
  offerStatus    String?      // "pending" | "accepted" | "declined" (null = regular message)

  isRead         Boolean      @default(false)

  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
  @@index([conversationId, isRead, senderId])
}

// ---------------------------------------------------------------------------
// Moderation / Reports
// ---------------------------------------------------------------------------

model Report {
  id         String       @id @default(cuid())

  reason     ReportReason
  details    String?      @db.Text

  reporterId String       @db.Uuid
  reporter   User         @relation(fields: [reporterId], references: [id])

  listingId  String?
  listing    Listing?     @relation(fields: [listingId], references: [id], onDelete: Cascade)

  resolved   Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@index([listingId])
  @@index([reporterId])
  @@index([resolved])
}

// ---------------------------------------------------------------------------
// SiteConfig — key/value store for platform-wide settings
// ---------------------------------------------------------------------------

model SiteConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// RwandaLocation — official administrative hierarchy reference table
// Seeded once from the Rwanda NEP village CSV (13,922 villages, 30 districts).
// Used as a read-only lookup for location pickers and listing enrichment.
// No FK from Listing — district name is the soft join key.
// ---------------------------------------------------------------------------

model RwandaLocation {
  id       Int    @id @default(autoincrement())
  province String
  district String
  sector   String
  cell     String
  village  String

  @@unique([province, district, sector, cell, village])
  @@index([district])
  @@index([district, sector])
  @@index([district, sector, cell])
}

// ---------------------------------------------------------------------------
// AdminAction — audit log for every moderation action
// ---------------------------------------------------------------------------

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String   @db.Uuid
  admin      User     @relation("AdminActions", fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String?
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt(sort: Desc)])
}
